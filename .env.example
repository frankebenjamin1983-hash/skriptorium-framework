# Vorlage – kopiere diese Datei zu ".env" und trage deine echten Werte ein.
# Die echte .env wird NIE committed (steht in .gitignore).

# ─── Claude (Anthropic) ─────────────────────────────────────────────
# Key erzeugen auf https://console.anthropic.com -> Settings -> API Keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Optional, nur falls du den Endpunkt mal aendern musst:
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ─── Grok (xAI) ─────────────────────────────────────────────────────
# Key erzeugen auf https://console.x.ai
XAI_API_KEY=xai-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
XAI_BASE_URL=https://api.x.ai/v1

# ─── Quellordner (optional) ─────────────────────────────────────────
# Pfad zu deinen *_extracted.md-Dateien. Wenn nicht gesetzt, sucht der
# Importer in ../knowledge_source relativ zum Projekt-Root.
# PYCOMPENDIUM_SOURCE_DIR=

# ─── Chroma-Vectorstore (optional, fuer sources/chroma_reader.py) ────
# PYCOMPENDIUM_CHROMA_DIR=
# PYCOMPENDIUM_CHROMA_COLLECTION=knowledge
